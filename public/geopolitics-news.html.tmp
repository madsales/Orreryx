<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#07070a;--bg2:#0d0d12;--bg3:#12121a;--bg4:#1a1a24;
  --brd:rgba(255,255,255,.06);--brd2:rgba(255,255,255,.1);
  --txt:#f2f2ee;--txt2:#a8a8a2;--txt3:#585858;
  --red:#e03836;--red2:rgba(224,56,54,.12);
  --grn:#3ab860;--gold:#d4a843;
  --sans:'Inter',system-ui,sans-serif;--mono:'IBM Plex Mono',monospace;
}
html{scroll-behavior:smooth}
body{background:var(--bg);color:var(--txt);font-family:var(--sans);line-height:1.6}
a{color:var(--red);text-decoration:none}
a:hover{text-decoration:underline}
::-webkit-scrollbar{width:3px}::-webkit-scrollbar-thumb{background:#2a2a3a;border-radius:2px}

nav{position:fixed;top:0;left:0;right:0;z-index:200;height:56px;padding:0 32px;display:flex;align-items:center;gap:16px;background:rgba(7,7,10,.85);backdrop-filter:blur(20px);border-bottom:1px solid var(--brd)}
.nav-logo{font-family:var(--mono);font-size:14px;font-weight:700;color:var(--txt);text-decoration:none;letter-spacing:.05em}
.nav-spacer{flex:1}
.nav-cta{padding:8px 18px;font-size:12px;font-weight:600;color:#fff;text-decoration:none;border-radius:5px;background:var(--red)}
.nav-cta:hover{background:#c42e2c;text-decoration:none}
.nav-link{font-size:12px;color:var(--txt3);text-decoration:none}
.nav-link:hover{color:var(--txt2);text-decoration:none}

.page{max-width:860px;margin:0 auto;padding:100px 24px 80px}

.eyebrow{display:inline-flex;align-items:center;gap:8px;background:var(--red2);border:1px solid rgba(224,56,54,.2);border-radius:4px;padding:5px 12px;font-family:var(--mono);font-size:9px;font-weight:700;color:var(--red);letter-spacing:.14em;text-transform:uppercase;margin-bottom:24px}
.dot{width:5px;height:5px;border-radius:50%;background:var(--red);animation:blink 1.4s infinite;flex-shrink:0}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.2}}

h1{font-size:clamp(32px,4.5vw,56px);font-weight:800;line-height:1.08;letter-spacing:-.03em;margin-bottom:20px}
h1 em{font-style:normal;color:var(--red)}
.lead{font-size:16px;color:var(--txt2);max-width:620px;line-height:1.75;margin-bottom:40px}

.cta-row{display:flex;gap:12px;flex-wrap:wrap;margin-bottom:64px}
.btn-p{display:inline-flex;align-items:center;gap:8px;padding:13px 24px;border-radius:6px;font-size:13px;font-weight:600;text-decoration:none;background:var(--red);color:#fff}
.btn-p:hover{background:#c42e2c;text-decoration:none}
.btn-s{display:inline-flex;align-items:center;gap:8px;padding:13px 20px;border-radius:6px;font-size:13px;font-weight:500;text-decoration:none;color:var(--txt2);border:1px solid var(--brd2)}
.btn-s:hover{color:var(--txt);text-decoration:none}

.section{margin-bottom:64px}
h2{font-size:22px;font-weight:700;letter-spacing:-.02em;margin-bottom:8px;color:var(--txt)}
h3{font-size:16px;font-weight:600;margin-bottom:6px;color:var(--txt)}
.section-desc{font-size:14px;color:var(--txt2);margin-bottom:28px;max-width:620px;line-height:1.7}

.conflict-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:14px;margin-bottom:12px}
.conflict-card{background:var(--bg2);border:1px solid var(--brd);border-radius:8px;padding:18px 20px}
.conflict-region{font-family:var(--mono);font-size:8px;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:var(--red);margin-bottom:8px}
.conflict-card h3{font-size:14px;margin-bottom:6px}
.conflict-card p{font-size:12.5px;color:var(--txt2);line-height:1.6}
.severity{display:inline-flex;align-items:center;gap:5px;font-family:var(--mono);font-size:9px;font-weight:700;padding:3px 8px;border-radius:3px;margin-top:10px}
.sev-critical{background:rgba(224,56,54,.15);color:var(--red)}
.sev-high{background:rgba(212,168,67,.15);color:var(--gold)}
.sev-medium{background:rgba(58,184,96,.15);color:var(--grn)}

.source-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(160px,1fr));gap:10px;margin-bottom:12px}
.source-pill{background:var(--bg2);border:1px solid var(--brd);border-radius:6px;padding:10px 14px;font-size:12px;color:var(--txt2);display:flex;align-items:center;gap:8px}
.source-dot{width:6px;height:6px;border-radius:50%;background:var(--grn);flex-shrink:0}

.faq-list{display:flex;flex-direction:column;gap:0;border:1px solid var(--brd);border-radius:8px;overflow:hidden}
.faq-item{padding:20px 24px;border-bottom:1px solid var(--brd)}
.faq-item:last-child{border-bottom:none}
.faq-q{font-size:14px;font-weight:600;color:var(--txt);margin-bottom:8px}
.faq-a{font-size:13px;color:var(--txt2);line-height:1.7}

.feature-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:14px}
.feature-card{background:var(--bg2);border:1px solid var(--brd);border-radius:8px;padding:20px}
.feature-icon{font-size:22px;margin-bottom:12px}
.feature-card h3{font-size:14px;margin-bottom:6px}
.feature-card p{font-size:12.5px;color:var(--txt2);line-height:1.6}

footer{border-top:1px solid var(--brd);padding:32px 24px;text-align:center;font-size:12px;color:var(--txt3)}
footer a{color:var(--txt3)}
footer a:hover{color:var(--txt2)}
</style>
</head>
