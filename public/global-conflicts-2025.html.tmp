  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:      #07070a;
      --bg2:     #0e0e12;
      --bg3:     #16161c;
      --border:  rgba(255,255,255,.08);
      --text:    #e8e8e2;
      --muted:   #888882;
      --red:     #e03836;
      --amber:   #d4813a;
      --gold:    #d4a843;
      --green:   #3a9e6e;
      --blue:    #4a90d9;
      --r:       6px;
    }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
      font-size: 15px;
      line-height: 1.65;
    }

    /* NAV */
    nav {
      position: sticky; top: 0; z-index: 100;
      display: flex; align-items: center; justify-content: space-between;
      padding: 0 24px; height: 52px;
      background: rgba(7,7,10,.92);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--border);
    }
    .nav-logo { font-size: 17px; font-weight: 700; color: var(--text); text-decoration: none; letter-spacing: -.3px; }
    .nav-logo span { color: var(--red); }
    .nav-cta { background: var(--red); color: #fff; text-decoration: none; padding: 7px 16px; border-radius: var(--r); font-size: 12px; font-weight: 700; letter-spacing: .4px; }

    /* HERO */
    .hero {
      padding: 64px 24px 48px;
      max-width: 860px; margin: 0 auto;
      text-align: center;
    }
    .hero-badge {
      display: inline-flex; align-items: center; gap: 6px;
      font-size: 11px; font-weight: 600; color: var(--red); letter-spacing: .8px; text-transform: uppercase;
      background: rgba(224,56,54,.1); border: 1px solid rgba(224,56,54,.25);
      padding: 5px 12px; border-radius: 20px; margin-bottom: 20px;
    }
    .pulse { width: 6px; height: 6px; border-radius: 50%; background: var(--red); animation: pulse 1.5s infinite; }
    @keyframes pulse { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:.5;transform:scale(1.3)} }
    h1 { font-size: clamp(28px, 5vw, 44px); font-weight: 800; letter-spacing: -.6px; line-height: 1.15; margin-bottom: 18px; }
    h1 em { color: var(--red); font-style: normal; }
    .hero-sub { color: var(--muted); font-size: 16px; max-width: 600px; margin: 0 auto 32px; }
    .conflict-count-bar {
      display: flex; gap: 24px; justify-content: center; flex-wrap: wrap;
      padding: 20px 0; border-top: 1px solid var(--border); border-bottom: 1px solid var(--border);
      margin-bottom: 8px;
    }
    .count-item { text-align: center; }
    .count-num { font-size: 32px; font-weight: 800; line-height: 1; }
    .count-num.red { color: var(--red); }
    .count-num.amber { color: var(--amber); }
    .count-num.gold { color: var(--gold); }
    .count-label { font-size: 11px; color: var(--muted); text-transform: uppercase; letter-spacing: .6px; margin-top: 4px; }

    /* LAYOUT */
    .container { max-width: 860px; margin: 0 auto; padding: 0 24px 80px; }

    /* CONFLICT CARDS */
    .section-title {
      font-size: 11px; font-weight: 600; color: var(--muted); letter-spacing: .8px; text-transform: uppercase;
      margin-bottom: 16px; padding-bottom: 8px; border-bottom: 1px solid var(--border);
    }
    .conflict-card {
      background: var(--bg2); border: 1px solid var(--border); border-radius: var(--r);
      margin-bottom: 16px; overflow: hidden;
    }
    .card-header {
      display: flex; align-items: center; gap: 14px;
      padding: 16px 20px; cursor: pointer;
      border-bottom: 1px solid var(--border);
    }
    .card-header:hover { background: var(--bg3); }
    .conflict-flag { font-size: 26px; line-height: 1; flex-shrink: 0; }
    .card-header-text { flex: 1; }
    .card-title { font-size: 16px; font-weight: 700; margin-bottom: 3px; }
    .card-subtitle { font-size: 12px; color: var(--muted); }
    .risk-badge {
      display: flex; align-items: center; gap: 6px; flex-shrink: 0;
      font-size: 11px; font-weight: 700; letter-spacing: .4px; padding: 4px 10px;
      border-radius: 4px;
    }
    .risk-critical { background: rgba(224,56,54,.15); color: var(--red); border: 1px solid rgba(224,56,54,.3); }
    .risk-high     { background: rgba(212,129,58,.15); color: var(--amber); border: 1px solid rgba(212,129,58,.3); }
    .risk-medium   { background: rgba(212,168,67,.15); color: var(--gold); border: 1px solid rgba(212,168,67,.3); }
    .card-body { padding: 20px; }
    .stats-row {
      display: grid; grid-template-columns: repeat(auto-fit, minmax(120px, 1fr)); gap: 12px;
      margin-bottom: 16px;
    }
    .stat-box { background: var(--bg3); border-radius: 4px; padding: 12px; }
    .stat-label { font-size: 10px; color: var(--muted); text-transform: uppercase; letter-spacing: .5px; margin-bottom: 4px; }
    .stat-value { font-size: 17px; font-weight: 700; }
    .stat-value.red { color: var(--red); }
    .stat-value.gold { color: var(--gold); }
    .stat-value.blue { color: var(--blue); }
    .stat-value.green { color: var(--green); }

    /* Risk bar */
    .risk-bar-row { display: flex; align-items: center; gap: 10px; margin-bottom: 8px; }
    .risk-bar-label { font-size: 11px; color: var(--muted); width: 120px; flex-shrink: 0; }
    .risk-bar-track { flex: 1; height: 6px; background: var(--bg3); border-radius: 3px; overflow: hidden; }
    .risk-bar-fill { height: 100%; border-radius: 3px; transition: width 1s cubic-bezier(.4,0,.2,1); }
    .risk-bar-pct { font-size: 11px; color: var(--muted); width: 32px; text-align: right; flex-shrink: 0; }

    .card-desc { font-size: 13.5px; color: var(--muted); line-height: 1.7; margin-bottom: 16px; }
    .market-impact { background: var(--bg3); border-radius: 4px; padding: 14px; margin-top: 4px; }
    .market-impact-title { font-size: 11px; color: var(--gold); font-weight: 600; text-transform: uppercase; letter-spacing: .5px; margin-bottom: 10px; }
    .impact-items { display: flex; flex-direction: column; gap: 6px; }
    .impact-item { display: flex; justify-content: space-between; align-items: baseline; font-size: 12px; }
    .impact-commodity { color: var(--muted); }
    .impact-effect { font-weight: 600; }
    .impact-effect.up { color: #3a9e6e; }
    .impact-effect.down { color: var(--red); }
    .impact-effect.watch { color: var(--gold); }

    /* ARTICLE */
    .article { margin: 48px 0; }
    .article h2 { font-size: 22px; font-weight: 700; margin: 32px 0 14px; letter-spacing: -.2px; }
    .article h3 { font-size: 16px; font-weight: 700; color: var(--text); margin: 24px 0 10px; }
    .article p { color: var(--muted); margin-bottom: 14px; font-size: 14.5px; }
    .article strong { color: var(--text); font-weight: 600; }

    /* TABLE */
    .data-table { width: 100%; border-collapse: collapse; margin: 20px 0; font-size: 13px; }
    .data-table th { text-align: left; font-size: 10px; color: var(--muted); text-transform: uppercase; letter-spacing: .6px; padding: 8px 12px; border-bottom: 1px solid var(--border); }
    .data-table td { padding: 10px 12px; border-bottom: 1px solid rgba(255,255,255,.04); color: var(--muted); }
    .data-table td:first-child { color: var(--text); font-weight: 600; }
    .data-table tr:hover td { background: var(--bg2); }

    /* FAQ */
    .faq { margin: 48px 0; }
    .faq h2 { font-size: 22px; font-weight: 700; margin-bottom: 20px; }
    details { border: 1px solid var(--border); border-radius: var(--r); margin-bottom: 10px; overflow: hidden; }
    details[open] { border-color: rgba(255,255,255,.14); }
    summary {
      padding: 16px 20px; font-weight: 600; font-size: 14.5px;
      cursor: pointer; list-style: none; display: flex; justify-content: space-between; align-items: center;
    }
    summary::-webkit-details-marker { display: none; }
    summary::after { content: '+'; color: var(--muted); font-size: 20px; font-weight: 300; flex-shrink: 0; }
    details[open] summary::after { content: '−'; }
    details p { padding: 0 20px 16px; color: var(--muted); font-size: 13.5px; line-height: 1.7; }

    /* CTA */
    .cta-box {
      background: linear-gradient(135deg, rgba(224,56,54,.12), rgba(212,168,67,.06));
      border: 1px solid rgba(224,56,54,.25); border-radius: var(--r);
      padding: 36px; text-align: center; margin: 40px 0;
    }
    .cta-box h2 { font-size: 22px; font-weight: 800; margin-bottom: 10px; }
    .cta-box p { color: var(--muted); font-size: 14px; margin-bottom: 24px; max-width: 480px; margin-left: auto; margin-right: auto; margin-bottom: 24px; }
    .btn-primary { display: inline-block; background: var(--red); color: #fff; text-decoration: none; padding: 13px 28px; border-radius: var(--r); font-weight: 700; font-size: 13px; letter-spacing: .4px; }
    .btn-primary:hover { opacity: .9; }
    .cta-note { font-size: 11px; color: var(--muted); margin-top: 12px; }

    /* RELATED */
    .related { margin-top: 40px; }
    .related h2 { font-size: 17px; font-weight: 700; margin-bottom: 16px; }
    .related-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 10px; }
    .related-link { display: block; background: var(--bg2); border: 1px solid var(--border); border-radius: var(--r); padding: 14px 16px; text-decoration: none; color: var(--text); font-size: 13px; font-weight: 500; }
    .related-link:hover { border-color: rgba(255,255,255,.18); background: var(--bg3); }
    .related-link span { display: block; font-size: 11px; color: var(--muted); margin-top: 3px; }

    /* FOOTER */
    footer {
      border-top: 1px solid var(--border); padding: 28px 24px;
      display: flex; flex-wrap: wrap; gap: 12px; justify-content: space-between; align-items: center;
      font-size: 12px; color: var(--muted);
    }
    footer a { color: var(--muted); text-decoration: none; }
    footer a:hover { color: var(--text); }
  </style>
</head>
<body>

<!-- NAV -->
<nav>
