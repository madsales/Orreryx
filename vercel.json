{
  "version": 2,
  "functions": {
    "api/*.js": { "maxDuration": 30 }
  },
  "routes": [
    { "src": "/api/anthropic",       "dest": "/api/anthropic.js" },
    { "src": "/api/paypal(.*)",      "dest": "/api/paypal.js" },
    { "src": "/api/events(.*)",      "dest": "/api/events.js" },
    { "src": "/api/gnews(.*)",       "dest": "/api/gnews.js" },
    { "src": "/api/send-magic",      "dest": "/api/send-magic.js" },
    { "src": "/api/verify-magic(.*)", "dest": "/api/verify-magic.js" },
    { "src": "/api/track",           "dest": "/api/track.js" },
    { "src": "/api/admin(.*)",       "dest": "/api/admin.js" },
    { "src": "/demo",                 "dest": "/demo.html" },
    { "src": "/sitemap.xml",          "dest": "/sitemap.xml" },
    { "src": "/robots.txt",           "dest": "/robots.txt" },
    { "src": "/callback",            "dest": "/callback.html" },
    { "src": "/app",                 "dest": "/app.html" },
    { "src": "/login",               "dest": "/login.html" },
    { "src": "/admin",               "dest": "/admin.html" },
    { "src": "/",                    "dest": "/index.html" }
  ]
}
