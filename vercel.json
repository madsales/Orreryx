{
  "version": 2,
  "outputDirectory": "public",
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "orreryx.io" }],
      "destination": "https://www.orreryx.io/$1",
      "permanent": true
    },
    { "source": "/north-korea-nuclear",  "destination": "/north-korea",           "permanent": true },
    { "source": "/iran-israel",           "destination": "/iran-nuclear",          "permanent": true },
    { "source": "/africa-conflict",       "destination": "/sudan-war",             "permanent": true },
    { "source": "/global-conflicts-2025", "destination": "/global-conflicts-2026", "permanent": true },
    { "source": "/ukraine-risk",          "destination": "/country/ukraine",       "permanent": true },
    { "source": "/russia-risk",           "destination": "/country/russia",        "permanent": true },
    { "source": "/china-risk",            "destination": "/country/china",         "permanent": true },
    { "source": "/iran-risk",             "destination": "/country/iran",          "permanent": true },
    { "source": "/israel-risk",           "destination": "/country/israel",        "permanent": true },
    { "source": "/india-risk",            "destination": "/country/india",         "permanent": true },
    { "source": "/pakistan-risk",         "destination": "/country/pakistan",      "permanent": true },
    { "source": "/north-korea-risk",      "destination": "/country/north-korea",   "permanent": true },
    { "source": "/taiwan-risk",           "destination": "/country/taiwan",        "permanent": true },
    { "source": "/saudi-arabia-risk",     "destination": "/country/saudi-arabia",  "permanent": true },
    { "source": "/:file.html",            "destination": "/:file",                 "permanent": true }
  ],
  "headers": [
    {
      "source": "/(.*).html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/(compare|map|watchlist|risk-timeline|market-impact|admin|app)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options",    "value": "nosniff" },
        { "key": "X-Frame-Options",            "value": "SAMEORIGIN" },
        { "key": "X-XSS-Protection",           "value": "1; mode=block" },
        { "key": "Referrer-Policy",            "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy",         "value": "camera=(), microphone=(), geolocation=(), payment=()" },
        { "key": "Strict-Transport-Security",  "value": "max-age=63072000; includeSubDomains; preload" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex" }
      ]
    }
  ],
  "crons": [
    { "path": "/api/ops-agent",      "schedule": "0 * * * *"         },
    { "path": "/api/social-post",    "schedule": "0 9,13,17,21 * * *" },
    { "path": "/api/breaking-news",  "schedule": "0 */2 * * *" },
    { "path": "/api/seo-agent",        "schedule": "0 6 * * 1"   },
    { "path": "/api/seo-orchestrator", "schedule": "0 5 * * 1"   },
    { "path": "/api/seo-geo",           "schedule": "0 6 * * 1"   },
    { "path": "/api/seo-chief",        "schedule": "0 9 * * 1"   },
    { "path": "/api/legal-agent",    "schedule": "0 7 * * 1"   },
    { "path": "/api/health-agent",   "schedule": "0 7 * * *"   },
    { "path": "/api/ceo-agent",      "schedule": "0 8 * * *"   },
    { "path": "/api/finance-agent",  "schedule": "0 8 * * 1"   },
    { "path": "/api/sales-agent",       "schedule": "0 9 * * *"   },
    { "path": "/api/ideas-agent",       "schedule": "30 1 * * *"  },
    { "path": "/api/churn-agent",       "schedule": "0 2 * * *"   },
    { "path": "/api/ads-agent",         "schedule": "0 7 * * 1"   },
    { "path": "/api/community-agent",   "schedule": "0 5 * * *"   },
    { "path": "/api/referral-agent",    "schedule": "0 10 * * 1"  },
    { "path": "/api/ab-agent",          "schedule": "0 6 * * 1"   },
    { "path": "/api/directory-agent",   "schedule": "0 8 * * 1"   },
    { "path": "/api/cro-agent",         "schedule": "0 9 * * 1"   },
    { "path": "/api/lead-magnet-agent", "schedule": "0 11 * * 1"  },
    { "path": "/api/seo-sprint",        "schedule": "0 6 * * *"   }
  ],
  "functions": {
    "api/anthropic.js":     { "maxDuration": 30 },
    "api/paypal.js":        { "maxDuration": 30 },
    "api/events.js":        { "maxDuration": 60 },
    "api/gnews.js":         { "maxDuration": 30 },
