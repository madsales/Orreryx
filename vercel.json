{
  "version": 2,
  "functions": {
    "api/*.js": {
      "maxDuration": 30
    }
  },
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/",
      "destination": "/home.html"
    },
    {
      "source": "/app",
      "destination": "/app.html"
    },
    {
      "source": "/login",
      "destination": "/login.html"
    },
    {
      "source": "/success",
      "destination": "/success.html"
    }
  ]
}