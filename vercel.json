{
  "version": 2,
  "outputDirectory": "public",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options",    "value": "nosniff" },
        { "key": "X-Frame-Options",            "value": "SAMEORIGIN" },
        { "key": "X-XSS-Protection",           "value": "1; mode=block" },
        { "key": "Referrer-Policy",            "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy",         "value": "camera=(), microphone=(), geolocation=(), payment=()" },
        { "key": "Strict-Transport-Security",  "value": "max-age=63072000; includeSubDomains; preload" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex" }
      ]
    }
  ],
  "crons": [
    { "path": "/api/buffer-post",  "schedule": "30 2 * * *" },
    { "path": "/api/social-post",  "schedule": "0 3 * * *"  }
  ],
  "functions": {
    "api/anthropic.js":  { "maxDuration": 30 },
    "api/paypal.js":     { "maxDuration": 30 },
    "api/events.js":     { "maxDuration": 30 },
    "api/gnews.js":      { "maxDuration": 30 },
    "api/feed.js":       { "maxDuration": 60 },
    "api/magic.js":      { "maxDuration": 30 },
    "api/admin.js":      { "maxDuration": 30 },
    "api/webhook.js":    { "maxDuration": 30 },
    "api/newsletter.js": { "maxDuration": 30 },
    "api/buffer-post.js":{ "maxDuration": 30 },
    "api/social-post.js":{ "maxDuration": 30 },
    "api/news-post.js":  { "maxDuration": 60 }
  },
  "routes": [
    { "src": "/api/buffer-post",      "dest": "/api/buffer-post.js" },
    { "src": "/api/social-post",      "dest": "/api/social-post.js" },
    { "src": "/api/news-post",        "dest": "/api/news-post.js" },
    { "src": "/api/og-image",         "dest": "/api/feed.js" },
    { "src": "/api/meta-webhook",     "dest": "/api/webhook.js" },
    { "src": "/api/v1/risks(.*)",     "dest": "/api/gnews.js?__route=risks" },
    { "src": "/api/newsletter(.*)",   "dest": "/api/newsletter.js" },
    { "src": "/api/anthropic",        "dest": "/api/anthropic.js" },
    { "src": "/api/paypal(.*)",       "dest": "/api/paypal.js" },
    { "src": "/api/events(.*)",       "dest": "/api/events.js" },
    { "src": "/api/gnews(.*)",        "dest": "/api/gnews.js" },
    { "src": "/api/videos(.*)",       "dest": "/api/feed.js" },
    { "src": "/api/quotes(.*)",       "dest": "/api/feed.js" },
    { "src": "/api/feed(.*)",         "dest": "/api/feed.js" },
    { "src": "/api/send-magic",       "dest": "/api/magic.js" },
    { "src": "/api/verify-magic(.*)", "dest": "/api/magic.js" },
    { "src": "/api/magic(.*)",        "dest": "/api/magic.js" },
    { "src": "/api/track",            "dest": "/api/admin.js" },
    { "src": "/api/admin(.*)",        "dest": "/api/admin.js" },
    { "src": "/api/webhook",          "dest": "/api/webhook.js" },
    { "src": "/api/session-check",    "dest": "/api/magic.js" },
    { "src": "/gold-price",            "dest": "/gold-price.html" },
    { "src": "/silver-price",          "dest": "/silver-price.html" },
    { "src": "/ww3-news",             "dest": "/ww3-news.html" },
    { "src": "/ukraine-war-map",      "dest": "/ukraine-war-map.html" },
    { "src": "/war-news",             "dest": "/war-news.html" },
